{
  "name": "laptop-store-backend",
  "version": "1.0.0",
  "description": "Backend for Laptop Store Application",
  "main": "src/app.js",
  "scripts": {
    "start": "node --max-old-space-size=1024 src/app.js",
    "dev": "nodemon src/app.js",
    "tunnel": "tunnel.bat",
    "test": "mocha",
    "test:simple": "node test/test-simple.js",
    "test:vnpay": "node test/test-vnpay-quick.js",
    "test:vnpay:watch": "nodemon test/test-vnpay-quick.js",
    "test:vnpay:signature": "node test/test-vnpay-signature-fix.js",
    "test:flow": "node test/test-with-order.js",
    "test:tier3": "node test/test-tier3.js",
    "seed": "node --expose-gc src/seeds/index.js",
    "seed:dry-run": "DRY_RUN=true node --expose-gc src/seeds/index.js -- --dry-run",
    "seed:incremental": "INCREMENTAL_SEED=true node --expose-gc src/seeds/index.js -- --incremental",
    "seed:products": "node --expose-gc src/seeds/index.js -- --products-only",
    "seed:products:incremental": "INCREMENTAL_SEED=true node --expose-gc src/seeds/index.js -- --products-only --incremental",
    "seed:tier1": "node --expose-gc src/scripts/seedTier1.js",
    "seed:tier2": "node --expose-gc src/scripts/seedTier2.js",
    "seed:unified": "node --expose-gc src/scripts/seedUnified.js",
    "seed:tier1:clear": "TIER1_CLEAR_EXISTING=true node --expose-gc src/scripts/seedTier1.js",
    "update-categories": "node src/scripts/updateCategoriesWithTranslations.js",
    "clear": "node --expose-gc src/clear.js",
    "fix": "node src/fix.js",
    "setup-ghn": "node scripts/setup-ghn.js",
    "create-ghn": "node scripts/create-ghn-provider.js",
    "fix-indexes": "node scripts/fix-indexes.js",
    "setup-i18n-indexes": "node scripts/setup-production-indexes.js",
    "test:blueprint": "node test-blueprint-3phase.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "axios": "^1.13.2",
    "bcryptjs": "^3.0.3",
    "cloudinary": "^2.9.0",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-async-handler": "^1.2.0",
    "express-jsdoc-swagger": "^1.8.0",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.0",
    "google-auth-library": "^10.6.1",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^9.0.1",
    "multer": "^2.0.2",
    "nodemailer": "^8.0.4",
    "qrcode": "^1.5.4",
    "socket.io": "^4.8.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "chai": "^6.2.1",
    "mocha": "^11.7.5",
    "nodemon": "^3.1.11",
    "sinon": "^21.0.0"
  },
  "overrides": {
    "ws": "^8.18.0",
    "diff": "8.0.3",
    "minimatch": "^10.2.1",
    "glob": "^10.4.2",
    "serialize-javascript": "^7.0.3",
    "@apidevtools/json-schema-ref-parser": "9.0.9"
  }
}