# ==================== API & SOCKET CONFIGURATION ====================
# Frontend public URL - Used for hreflang tags and canonical URLs (SEO)
NEXT_PUBLIC_FRONTEND_URL=https://manln.online

# Backend API base URL - Used by Next.js rewrites to proxy API calls and image uploads
NEXT_PUBLIC_API_BASE_URL=https://backend.manln.online/

# Socket.io Server URL - Direct connection to backend (Option A)
# Leave empty for auto-detection (will use http://localhost:5000 in dev, https://backend.manln.online in prod)
# Or set explicitly for custom environment (e.g., staging)
# NEXT_PUBLIC_SOCKET_URL=
